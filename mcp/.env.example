# PaySats MCP server — environment reference.
# Required
PAYSATS_API_KEY="pk_live_xxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional — defaults to https://api.paysats.io
# PAYSATS_BASE_URL="https://api.paysats.io"

# Transport: "stdio" (default) for Cursor / Claude Desktop, "http" for remote/Railway.
# PAYSATS_MCP_TRANSPORT="stdio"

# --- HTTP mode only ---------------------------------------------------------
# Bearer token required on every HTTP request (Authorization: Bearer <token>).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# PAYSATS_MCP_HTTP_TOKEN="change-me"

# Listen host. Use 127.0.0.1 locally; Railway/containers should set 0.0.0.0.
# PAYSATS_MCP_HOST="127.0.0.1"

# Port. Railway provides PORT automatically; that takes precedence.
# PAYSATS_MCP_PORT="3333"
# PORT="3333"

# Comma-separated allowlist for Host header (DNS-rebinding protection).
# Set to your public hostname(s) in production.
# PAYSATS_MCP_ALLOWED_HOSTS="mcp.example.com"

# Per-bearer rate limit (requests per minute) for the HTTP MCP endpoint.
# PAYSATS_MCP_RATE_LIMIT_PER_MINUTE="60"

# Optional override for server name shown to clients.
# PAYSATS_MCP_NAME="paysats"
