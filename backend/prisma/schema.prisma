generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderState {
  IDLE
  NWC_CONNECTED
  QR_SCANNED
  ROUTE_SHOWN
  LN_INVOICE_PAID
  BOLTZ_SWAP_PENDING
  USDT_RECEIVED
  USDC_SWAPPED
  P2PM_ORDER_PLACED
  P2PM_ORDER_CONFIRMED
  IDR_SETTLED
  COMPLETED
  FAILED
}

model Tenant {
  id            String    @id @default(cuid())
  name          String
  webhookUrl    String?
  webhookSecret String?
  createdAt     DateTime  @default(now())
  apiKeys       ApiKey[]
  orders        Order[]
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** Public prefix shown to integrators (e.g. "pk_live_abc123"). Used as lookup key. */
  prefix     String    @unique
  /** sha256 hex of the full API key (prefix.secret). */
  hash       String
  label      String?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model Order {
  id               String     @id @default(cuid())
  /** Tenant that created this order via the SDK (null for legacy/internal web app orders). */
  tenantId         String?
  tenant           Tenant?    @relation(fields: [tenantId], references: [id])
  state            OrderState @default(IDLE)
  satAmount        Int        @default(0)
  usdtAmount       Float?
  usdcAmount       Float?
  /** Human IDR face value of IDRX received on Base (bank / IDRX path). */
  idrxAmountIdr    Float?
  idrAmount        Float?
  btcIdr           Float?
  btcIdrFetchedAt  DateTime?
  boltzSwapId      String?
  /** Boltz swap LN invoice (BOLT11) paid by the agent — for payment proof URLs. */
  boltzLnInvoice   String?
  /** Preimage from NWC after paying the Boltz invoice (pairs with boltzLnInvoice on validate-payment.com). */
  boltzLnPreimage  String?
  boltzTxHash      String?
  swapTxHash       String?
  p2pmOrderId      String?
  p2pmPayoutMethod String?
  /** IDRX redeem-request bankCode from GET /transaction/method (e.g. 014 BCA, 1011 GOPAY). */
  idrxPayoutBankCode String?
  /** IDRX redeem-request bankName (must match methods list for validation). */
  idrxPayoutBankName String?
  payoutRecipient  String?
  /** Display / legal name for IDRX redeem (bank transfer). */
  bankAccountName  String?
  /** Base chain burn tx (IDRX burnWithAccountNumber). */
  idrxBurnTxHash   String?
  /** IDRX redeem-request API data.id when returned. */
  idrxRedeemId     String?
  invoiceBolt11    String?
  /** Spark LightningReceiveRequest id — used to poll payment status via getLightningReceiveRequest. */
  invoiceLnId      String?
  /** lightning | cbbtc | btcb — when set, user funds via wrapped BTC to EVM Safe instead of LN invoice. */
  depositChannel     String?
  depositChainId     Int?
  depositTokenAddress String?
  depositToAddress    String?
  invoiceExpiresAt DateTime?
  invoicePaidAt    DateTime?
  invoicePaymentHash String?
  merchantName     String?
  qrisPayload      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  completedAt      DateTime?

  @@index([tenantId, createdAt])
}
