{
  "name": "paysats-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/ensure-patchright-browsers.cjs",
    "dev": "tsx watch src/index.ts",
    "p2p:executor": "tsx watch src/p2p-server.ts",
    "p2p:executor:run": "tsx src/p2p-server.ts",
    "p2p:nav-test": "tsx scripts/p2pm-nav-test.ts",
    "lifi:quote:idrx": "tsx scripts/lifi-quote-idrx-base.ts",
    "lifi:quote:cbbtc:idrx": "tsx scripts/lifi-quote-cbbtc-idrx.ts",
    "lifi:quote:btcb:idrx": "tsx scripts/lifi-quote-btcb-idrx.ts",
    "lifi:exec:idrx": "tsx scripts/lifi-exec-arb-usdt-base-idrx.ts",
    "lifi:exec:cbbtc:idrx": "tsx scripts/lifi-exec-cbbtc-base-idrx.ts",
    "lifi:exec:btcb:idrx": "tsx scripts/lifi-exec-btcb-bsc-idrx.ts",
    "burn:idrx": "tsx scripts/burn-idrx-base.ts",
    "idrx:bank-hash": "tsx scripts/idrx-bank-hash.ts",
    "idrx:methods": "tsx scripts/idrx-transaction-methods.ts",
    "liquidity:bump-stats": "tsx scripts/bump-liquidity-display-stats.ts",
    "idrx:redeem:bca": "tsx scripts/idrx-redeem-bca.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "prisma migrate deploy && PLAYWRIGHT_BROWSERS_PATH=0 node dist/index.js",
    "start:p2p-executor": "PLAYWRIGHT_BROWSERS_PATH=0 node dist/p2p-server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@tetherto/wdk-wallet-evm-erc-4337": "^1.0.0-beta.5",
    "@tetherto/wdk-wallet-spark": "^1.0.0-beta.17",
    "axios": "^1.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "patchright": "^1.52.5",
    "prisma": "^6.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.30",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
