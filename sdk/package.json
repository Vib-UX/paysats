{
  "name": "@paysats/sdk",
  "version": "0.1.2",
  "description": "Official Node client for paysats — Bitcoin to Indonesian Rupiah (bank or e-wallet).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "paysats",
    "lightning",
    "bitcoin",
    "offramp",
    "idr",
    "indonesia",
    "sdk"
  ],
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "homepage": "https://paysats.exchange",
  "publishConfig": {
    "access": "public"
  }
}
